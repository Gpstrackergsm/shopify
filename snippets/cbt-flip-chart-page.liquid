  </div>

  <script>
    // Sticky CTA show/hide on scroll
    const cbtSticky = document.getElementById('cbt-sticky-cta');
    const cbtHeroBtn = document.getElementById('cbt-hero-btn');
    window.addEventListener('scroll', function() {
      if (!cbtSticky || !cbtHeroBtn) return;
      if (cbtHeroBtn.getBoundingClientRect().bottom < 0) {
        cbtSticky.classList.add('visible');
      } else {
        cbtSticky.classList.remove('visible');
      }
    }, { passive: true });

    // Scroll-in animations via IntersectionObserver
    var cbtObserver = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
          cbtObserver.unobserve(entry.target);
        }
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });

    document.querySelectorAll(
      '.cbt-card, .cbt-feature-item, .cbt-review-card, .cbt-who-card, .cbt-condition-pill, .cbt-stat-card'
    ).forEach(function(el, i) {
      el.style.opacity = '0';
      el.style.transform = 'translateY(28px)';
      el.style.transition = 'opacity 0.6s ' + (i * 0.05) + 's cubic-bezier(0.16,1,0.3,1), transform 0.6s ' + (i * 0.05) + 's cubic-bezier(0.16,1,0.3,1)';
      cbtObserver.observe(el);
    });
  </script>

</body>
</html>
