  }

  .bb-grid {
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:24px;
    max-width:1100px;
    margin:0 auto;
  }

  .bb-card {
    background:var(--bb-glass);
    border:1px solid var(--bb-border);
    border-radius:var(--bb-radius);
    padding:32px 22px;
    display:flex;flex-direction:column;align-items:center;text-align:center;
    transition:var(--bb-ease);
    backdrop-filter:blur(10px);
    position:relative;overflow:hidden;
  }
  .bb-card::before {
    content:'';position:absolute;inset:0;
    background:linear-gradient(135deg,rgba(245,158,11,0.05),transparent,rgba(16,185,129,0.03));
    opacity:0;transition:opacity 0.3s;
  }
  .bb-card:hover { transform:translateY(-10px);border-color:rgba(245,158,11,0.35);box-shadow:0 24px 60px rgba(0,0,0,0.45),0 0 40px var(--bb-gold-glow); }
  .bb-card:hover::before { opacity:1; }

  .bb-card-num {
    position:absolute;top:14px;right:14px;
    width:30px;height:30px;
