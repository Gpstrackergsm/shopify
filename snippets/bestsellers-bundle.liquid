<div class="bb-sticky" id="bb-sticky">
  <span class="bb-sticky-text">The Therapist's Toolkit Bundle — <span>$29.00</span></span>
  <button class="bb-btn bb-btn-primary bb-btn-sm" onclick="bbCheckout()">Buy Now</button>
</div>

<script>
  // Sticky bar
  const heroCta = document.getElementById('hero-cta');
  const stickyBar = document.getElementById('bb-sticky');
  window.addEventListener('scroll', () => {
    const rect = heroCta.getBoundingClientRect();
    stickyBar.classList.toggle('show', rect.bottom < 0);
  }, { passive: true });

  // Fade-up on scroll
  const fadeEls = document.querySelectorAll('.bb-fade');
  const obs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); obs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  fadeEls.forEach(el => obs.observe(el));

  // One-click checkout
  function bbCheckout() {
    const variants = [
      '{{ v1.id }}', '{{ v2.id }}', '{{ v3.id }}',
      '{{ v4.id }}', '{{ v5.id }}', '{{ v6.id }}'
    ];
    if (variants.some(v => !v || v === '')) { alert('Bundle error. Please try again.'); return; }
    document.querySelectorAll('.bb-btn-primary').forEach(b => { b.textContent = 'Processing…'; b.disabled = true; });
    const items = variants.map(id => ({ id: parseInt(id), quantity: 1 }));
    fetch('/cart/clear.js', { method: 'POST' })
      .then(() => fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items })
      }))
      .then(r => r.json())
      .then(() => { window.location.href = '/checkout'; })
      .catch(err => {
        console.error(err);
        document.querySelectorAll('.bb-btn-primary').forEach(b => { b.textContent = 'Get Bundle — $29'; b.disabled = false; });
        alert('Something went wrong. Please try again.');
      });
  }
</script>
