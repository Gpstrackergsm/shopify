  .bb-card-title { font-size:0.92rem;font-weight:700;line-height:1.4;color:var(--bb-text); }

  /* ── FEATURES ── */
  .bb-features { padding:80px 24px;background:var(--bb-bg2);border-top:1px solid var(--bb-border);border-bottom:1px solid var(--bb-border); }
  .bb-feat-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:32px;max-width:1000px;margin:0 auto; }
  .bb-feat-card { text-align:center;padding:36px 20px; }
