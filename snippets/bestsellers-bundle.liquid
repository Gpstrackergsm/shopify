  .bb-orb-3 { width:320px;height:320px;background:radial-gradient(circle,rgba(99,102,241,0.08),transparent 70%);bottom:0;left:-60px; }

  .bb-hero-inner { position:relative;z-index:1;max-width:820px; }

  .bb-badge {
