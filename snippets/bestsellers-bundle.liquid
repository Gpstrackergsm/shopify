  .bb-gold-text {
    background: linear-gradient(135deg, var(--bb-gold), #fb923c);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .bb-green-text {
    background: linear-gradient(135deg, var(--bb-green), #06b6d4);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .bb-hero-sub {
    font-size: 1.15rem;
    color: var(--bb-dim);
