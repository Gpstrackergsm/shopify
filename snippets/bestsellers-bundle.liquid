    content:'';position:absolute;
    bottom:-10px;left:50%;transform:translateX(-50%);
    width:75%;height:18px;
    background:var(--bb-gold-glow);
    filter:blur(14px);border-radius:50%;
    opacity:0;transition:opacity 0.3s;
  }
