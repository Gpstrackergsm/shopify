  .bb-feat-title { font-size:1.05rem;font-weight:800;margin-bottom:10px;color:var(--bb-text); }
  .bb-feat-desc { font-size:0.88rem;color:var(--bb-muted);line-height:1.75; }

  /* ── FINAL CTA ── */
  .bb-final {
    padding:120px 24px;text-align:center;
    position:relative;overflow:hidden;
  }
  .bb-final-orb {
    position:absolute;width:700px;height:700px;border-radius:50%;
    background:radial-gradient(circle,rgba(245,158,11,0.09),transparent 70%);
    top:50%;left:50%;transform:translate(-50%,-50%);
    filter:blur(80px);pointer-events:none;
  }
  .bb-final-inner { position:relative;z-index:1;max-width:640px;margin:0 auto; }
  .bb-final h2 { font-size:clamp(2rem,4vw,3.4rem);font-weight:900;letter-spacing:-1.5px;margin-bottom:18px;line-height:1.1; }
  .bb-final p { font-size:1.1rem;color:var(--bb-dim);margin-bottom:44px;line-height:1.75; }

  /* ── STICKY BAR ── */
  .bb-sticky {
    position:fixed;bottom:0;left:0;right:0;z-index:999;
    padding:16px 32px;
    background:rgba(12,15,26,0.88);
    backdrop-filter:blur(24px);
    -webkit-backdrop-filter:blur(24px);
    border-top:1px solid var(--bb-border);
    display:flex;align-items:center;justify-content:center;gap:32px;
    transform:translateY(100%);
    transition:transform 0.4s cubic-bezier(0.4,0,0.2,1);
    box-shadow:0 -20px 60px rgba(0,0,0,0.55);
  }
  .bb-sticky.show { transform:translateY(0); }
  .bb-sticky-text { font-size:1rem;font-weight:700;color:var(--bb-text); }
  .bb-sticky-text span { color:var(--bb-gold); }

  /* ── ANIMATIONS ── */
  .bb-fade { opacity:0;transform:translateY(32px);transition:opacity 0.75s ease,transform 0.75s ease; }
  .bb-fade.in { opacity:1;transform:translateY(0); }
  .bb-fade:nth-child(2){transition-delay:0.1s}
  .bb-fade:nth-child(3){transition-delay:0.2s}
  .bb-fade:nth-child(4){transition-delay:0.3s}
  .bb-fade:nth-child(5){transition-delay:0.4s}
  .bb-fade:nth-child(6){transition-delay:0.5s}

  /* ── RESPONSIVE ── */
  @media(max-width:900px){ .bb-grid{grid-template-columns:repeat(2,1fr);} .bb-feat-grid{grid-template-columns:1fr;} }
  @media(max-width:600px){
    .bb-grid{grid-template-columns:repeat(2,1fr);gap:14px;}
    .bb-card{padding:20px 14px;}
    .bb-hero h1{letter-spacing:-1.5px;}
    .bb-sticky{flex-direction:column;gap:10px;padding:14px 20px;}
    .bb-price-main{font-size:4rem;}
    .bb-ribbon-inner{gap:24px;}
  }
</style>

