  <script>
    const narmStickyCta = document.getElementById('narm-sticky-cta');
    const narmHeroBtn = document.getElementById('hero-btn');
    window.addEventListener('scroll', () => {
      if (!narmStickyCta || !narmHeroBtn) return;
      if (narmHeroBtn.getBoundingClientRect().bottom < 0) {
        narmStickyCta.classList.add('visible');
      } else {
        narmStickyCta.classList.remove('visible');
      }
    });
    const narmObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.narm-feature-item, .narm-pillar-card, .narm-review-card, .narm-author-card, .narm-learn-item').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'all 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
      narmObserver.observe(el);
    });
  </script>

