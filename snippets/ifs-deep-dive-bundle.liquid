    position:relative;overflow:hidden;
  }
  .ifs-card::before { content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(167,139,250,0.06),transparent,rgba(251,113,133,0.04));opacity:0;transition:opacity 0.3s; }
  .ifs-card:hover { transform:translateY(-10px);border-color:rgba(167,139,250,0.35);box-shadow:0 24px 60px rgba(0,0,0,0.5),0 0 40px var(--c-purple-glow); }
  .ifs-card:hover::before { opacity:1; }

  .ifs-card-num { position:absolute;top:14px;right:14px;width:30px;height:30px;background:linear-gradient(135deg,var(--c-purple),var(--c-purple2));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:900;color:#fff; }

  .ifs-cover-wrap { width:130px;height:195px;margin-bottom:22px;position:relative;flex-shrink:0; }
  .ifs-cover-wrap::after { content:'';position:absolute;bottom:-10px;left:50%;transform:translateX(-50%);width:75%;height:18px;background:var(--c-purple-glow);filter:blur(14px);border-radius:50%;opacity:0;transition:opacity 0.3s; }
  .ifs-card:hover .ifs-cover-wrap::after { opacity:1; }

  .ifs-cover { width:100%;height:100%;object-fit:contain;border-radius:6px;box-shadow:0 14px 40px rgba(0,0,0,0.6),4px 4px 0 rgba(0,0,0,0.25);transition:transform 0.35s ease; }
  .ifs-card:hover .ifs-cover { transform:rotate(-2.5deg) scale(1.05); }
  .ifs-card-title { font-size:0.92rem;font-weight:700;line-height:1.4;color:var(--c-text); }

  /* ── FEATURES ── */
  .ifs-features { padding:80px 24px;background:var(--c-bg2);border-top:1px solid var(--c-border);border-bottom:1px solid var(--c-border); }
  .ifs-feat-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:32px;max-width:1000px;margin:0 auto; }
  .ifs-feat { text-align:center;padding:36px 20px; }
  .ifs-feat-icon { font-size:2.6rem;margin-bottom:16px;display:block; }
  .ifs-feat-title { font-size:1.05rem;font-weight:800;margin-bottom:10px;color:var(--c-text); }
  .ifs-feat-desc { font-size:0.88rem;color:var(--c-muted);line-height:1.75; }

  /* ── FINAL CTA ── */
  .ifs-final { padding:120px 24px;text-align:center;position:relative;overflow:hidden; }
  .ifs-final-orb { position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(167,139,250,0.1),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);filter:blur(80px);pointer-events:none; }
  .ifs-final-inner { position:relative;z-index:1;max-width:640px;margin:0 auto; }
  .ifs-final h2 { font-size:clamp(2rem,4vw,3.4rem);font-weight:900;letter-spacing:-1.5px;margin-bottom:18px;line-height:1.1; }
  .ifs-final p { font-size:1.1rem;color:var(--c-dim);margin-bottom:44px;line-height:1.75; }

  /* ── STICKY ── */
  .ifs-sticky { position:fixed;bottom:0;left:0;right:0;z-index:999;padding:16px 32px;background:rgba(8,9,15,0.9);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-top:1px solid var(--c-border);display:flex;align-items:center;justify-content:center;gap:32px;transform:translateY(100%);transition:transform 0.4s cubic-bezier(0.4,0,0.2,1);box-shadow:0 -20px 60px rgba(0,0,0,0.6); }
  .ifs-sticky.show { transform:translateY(0); }
  .ifs-sticky-text { font-size:1rem;font-weight:700;color:var(--c-text); }
  .ifs-sticky-text span { color:var(--c-purple); }

  /* ── FADE ── */
  .ifs-fade { opacity:0;transform:translateY(32px);transition:opacity 0.75s ease,transform 0.75s ease; }
  .ifs-fade.in { opacity:1;transform:translateY(0); }
  .ifs-fade:nth-child(2){transition-delay:0.1s}.ifs-fade:nth-child(3){transition-delay:0.2s}
  .ifs-fade:nth-child(4){transition-delay:0.3s}.ifs-fade:nth-child(5){transition-delay:0.4s}
  .ifs-fade:nth-child(6){transition-delay:0.5s}

  @media(max-width:900px){ .ifs-grid{grid-template-columns:repeat(2,1fr);} .ifs-feat-grid{grid-template-columns:1fr;} .ifs-parts-row{gap:16px;} }
  @media(max-width:600px){ .ifs-grid{grid-template-columns:repeat(2,1fr);gap:14px;} .ifs-card{padding:18px 12px;} .ifs-hero h1{letter-spacing:-1.5px;} .ifs-sticky{flex-direction:column;gap:10px;padding:14px 20px;} .ifs-price-main{font-size:4rem;} }
</style>

