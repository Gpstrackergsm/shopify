<style>
  .ifs-wrap *, .ifs-wrap *::before, .ifs-wrap *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .ifs-wrap {
    --c-bg: #08090f;
    --c-bg2: #0e1019;
    --c-bg3: #141624;
    --c-glass: rgba(255,255,255,0.04);
    --c-border: rgba(255,255,255,0.07);
    --c-purple: #a78bfa;
    --c-purple2: #7c3aed;
    --c-purple-glow: rgba(167,139,250,0.2);
    --c-rose: #fb7185;
    --c-rose-glow: rgba(251,113,133,0.15);
    --c-gold: #fbbf24;
    --c-text: #f1f5f9;
    --c-muted: #64748b;
    --c-dim: #94a3b8;
    --c-radius: 20px;
    --c-ease: all 0.35s cubic-bezier(0.4,0,0.2,1);
    font-family: 'Outfit', sans-serif;
    background: var(--c-bg);
    color: var(--c-text);
    overflow-x: hidden;
  }

  /* ── HERO ── */
  .ifs-hero {
    min-height: 90vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    padding: 60px 24px 80px;
    position: relative; overflow: hidden;
  }
  .ifs-orb { position:absolute; border-radius:50%; filter:blur(120px); pointer-events:none; }
  .ifs-orb-1 { width:700px;height:700px;background:radial-gradient(circle,rgba(167,139,250,0.14),transparent 70%);top:-180px;left:50%;transform:translateX(-50%); }
  .ifs-orb-2 { width:420px;height:420px;background:radial-gradient(circle,rgba(251,113,133,0.1),transparent 70%);bottom:0;right:-80px; }
  .ifs-orb-3 { width:350px;height:350px;background:radial-gradient(circle,rgba(251,191,36,0.07),transparent 70%);bottom:0;left:-60px; }

  .ifs-hero-inner { position:relative;z-index:1;max-width:820px; }

  .ifs-badge {
    display:inline-flex;align-items:center;gap:8px;
    background:rgba(167,139,250,0.08);
    border:1px solid rgba(167,139,250,0.2);
    border-radius:999px;padding:8px 22px;
    font-size:0.78rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;
    color:var(--c-purple);margin-bottom:28px;backdrop-filter:blur(12px);
  }
  .ifs-badge-dot {
    width:7px;height:7px;background:var(--c-purple);border-radius:50%;
    animation:ifs-pulse 2s ease-in-out infinite;
  }
  @keyframes ifs-pulse { 0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.4;transform:scale(0.7);} }

  .ifs-hero h1 {
    font-size:clamp(2.6rem,6vw,4.8rem);font-weight:900;line-height:1.05;
    letter-spacing:-2px;margin-bottom:24px;
  }
  .ifs-purple-text {
    background:linear-gradient(135deg,var(--c-purple),#c084fc);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  }
  .ifs-rose-text {
    background:linear-gradient(135deg,var(--c-rose),#f43f5e);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  }

  .ifs-sub {
    font-size:1.15rem;color:var(--c-dim);max-width:580px;
    margin:0 auto 44px;line-height:1.75;font-weight:400;
  }

  /* Price */
  .ifs-price-row { display:flex;align-items:center;justify-content:center;gap:20px;margin-bottom:36px;flex-wrap:wrap; }
  .ifs-price-main { font-size:5.5rem;font-weight:900;line-height:1;letter-spacing:-4px;color:var(--c-text); }
  .ifs-price-main sup { font-size:2.2rem;letter-spacing:0;vertical-align:super; }
  .ifs-price-meta { display:flex;flex-direction:column;align-items:flex-start;gap:6px; }
  .ifs-price-was { font-size:1.1rem;color:var(--c-muted);text-decoration:line-through;font-weight:600; }
  .ifs-save-pill {
    font-size:0.82rem;font-weight:800;color:var(--c-purple);
    background:rgba(167,139,250,0.12);padding:4px 12px;border-radius:999px;
    letter-spacing:0.5px;border:1px solid rgba(167,139,250,0.25);
  }

  /* Button */
  .ifs-btn {
    display:inline-flex;align-items:center;gap:10px;
    font-family:'Outfit',sans-serif;font-weight:800;
    border:none;border-radius:16px;cursor:pointer;
    transition:var(--c-ease);text-decoration:none;
    position:relative;overflow:hidden;letter-spacing:-0.3px;
  }
  .ifs-btn::after { content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.18),transparent);opacity:0;transition:opacity 0.2s; }
  .ifs-btn:hover::after { opacity:1; }
  .ifs-btn-primary {
    background:linear-gradient(135deg,var(--c-purple),var(--c-purple2));
    color:#fff;padding:18px 52px;font-size:1.15rem;
    box-shadow:0 0 40px var(--c-purple-glow),0 6px 20px rgba(0,0,0,0.4);
  }
  .ifs-btn-primary:hover { transform:translateY(-3px);box-shadow:0 0 60px var(--c-purple-glow),0 10px 30px rgba(0,0,0,0.5); }
  .ifs-btn-sm { font-size:0.9rem;padding:11px 24px;border-radius:12px; }

  .ifs-trust { display:flex;align-items:center;justify-content:center;gap:24px;margin-top:22px;flex-wrap:wrap; }
  .ifs-trust-item { display:flex;align-items:center;gap:6px;font-size:0.82rem;color:var(--c-muted);font-weight:500; }
  .ifs-trust-item svg { color:var(--c-purple); }

  /* ── WHAT IS IFS ── */
