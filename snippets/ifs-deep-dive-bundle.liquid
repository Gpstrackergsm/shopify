  .ifs-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:24px;max-width:1100px;margin:0 auto; }

  .ifs-card {
    background:var(--c-glass);border:1px solid var(--c-border);border-radius:var(--c-radius);
    padding:32px 22px;display:flex;flex-direction:column;align-items:center;
