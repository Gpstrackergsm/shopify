  .ifs-explainer-inner { max-width:700px;margin:0 auto; }
  .ifs-explainer h2 { font-size:clamp(1.6rem,3.5vw,2.4rem);font-weight:900;letter-spacing:-1px;margin-bottom:18px; }
  .ifs-explainer p { font-size:1rem;color:var(--c-dim);line-height:1.8; }
  .ifs-parts-row { display:flex;align-items:center;justify-content:center;gap:32px;margin-top:40px;flex-wrap:wrap; }
  .ifs-part {
    background:var(--c-glass);border:1px solid var(--c-border);
