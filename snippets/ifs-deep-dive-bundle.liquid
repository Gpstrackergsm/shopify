<script>
  const ifsHeroCta = document.getElementById('ifs-hero-cta');
  const ifsSticky  = document.getElementById('ifs-sticky');
  window.addEventListener('scroll', () => {
    ifsSticky.classList.toggle('show', ifsHeroCta.getBoundingClientRect().bottom < 0);
  }, { passive: true });

  const ifsFades = document.querySelectorAll('.ifs-fade');
  const ifsObs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); ifsObs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  ifsFades.forEach(el => ifsObs.observe(el));

  function ifsCheckout() {
    const variants = [
      '{{ v1.id }}','{{ v2.id }}','{{ v3.id }}',
      '{{ v4.id }}','{{ v5.id }}','{{ v6.id }}'
    ];
    if (variants.some(v => !v || v === '')) { alert('Bundle error. Please try again.'); return; }
    document.querySelectorAll('.ifs-btn-primary').forEach(b => { b.textContent = 'Processing…'; b.disabled = true; });
    fetch('/cart/clear.js', { method: 'POST' })
      .then(() => fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: variants.map(id => ({ id: parseInt(id), quantity: 1 })) })
      }))
      .then(r => r.json())
      .then(() => { window.location.href = '/checkout'; })
      .catch(err => {
        console.error(err);
        document.querySelectorAll('.ifs-btn-primary').forEach(b => { b.textContent = 'Get Bundle — $29'; b.disabled = false; });
        alert('Something went wrong. Please try again.');
      });
  }
</script>
