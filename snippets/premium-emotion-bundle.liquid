  <!-- STICKY BAR -->
  <div class="sticky-bar" id="sticky-bar">
    <span class="sticky-bar-text">Emotional Mastery Bundle — <span>$29.00</span></span>
    <button class="btn btn-primary btn-sm" onclick="checkoutBundle()">Buy Now</button>
  </div>

  <script>
    // ─── STICKY BAR ───
    const heroBtn = document.getElementById('hero-btn');
    const stickyBar = document.getElementById('sticky-bar');

    window.addEventListener('scroll', () => {
      const rect = heroBtn.getBoundingClientRect();
      if (rect.bottom < 0) {
        stickyBar.classList.add('visible');
      } else {
        stickyBar.classList.remove('visible');
      }
    }, { passive: true });

    // ─── FADE-UP ON SCROLL ───
    const fadeEls = document.querySelectorAll('.fade-up');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    fadeEls.forEach(el => observer.observe(el));

    // ─── ONE-CLICK CHECKOUT ───
    function checkoutBundle() {
      const variants = [
        '{{ v1.id }}',
        '{{ v2.id }}',
        '{{ v3.id }}',
        '{{ v4.id }}',
        '{{ v5.id }}',
        '{{ v6.id }}'
      ];

      if (variants.some(v => !v || v === '')) {
        alert('Bundle configuration error. Please try again.');
        return;
      }

      document.querySelectorAll('.btn-primary').forEach(btn => {
        btn.textContent = 'Processing...';
        btn.disabled = true;
      });

      const items = variants.map(id => ({ id: parseInt(id), quantity: 1 }));

      fetch('/cart/clear.js', { method: 'POST' })
        .then(() => fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items })
        }))
        .then(res => res.json())
        .then(() => { window.location.href = '/checkout'; })
        .catch(err => {
          console.error(err);
          document.querySelectorAll('.btn-primary').forEach(btn => {
            btn.textContent = 'Get Bundle — $29';
            btn.disabled = false;
          });
          alert('Something went wrong. Please try again.');
        });
    }
  </script>

