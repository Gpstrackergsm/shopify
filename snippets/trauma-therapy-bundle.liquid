  <script>
    // FAQ Toggle
    document.querySelectorAll('.faq-question').forEach(q => {
      q.addEventListener('click', () => {
        const item = q.parentElement;
        item.classList.toggle('active');
      });
    });

    // Reveal sticky CTA on scroll
    const heroBtn = document.getElementById('hero-btn');
    const stickyCta = document.getElementById('sticky-cta');
    
    window.addEventListener('scroll', () => {
      if (heroBtn && stickyCta) {
        if (heroBtn.getBoundingClientRect().bottom < 0) {
          stickyCta.classList.add('show');
        } else {
          stickyCta.classList.remove('show');
        }
      }
    });

    // Handle Add to Cart & Checkout
    function checkoutBundle() {
      // These liquid variables will be empty strings if the variant doesn't exist
      const items = [
        { id: '{{ v1.id }}', quantity: 1 },
        { id: '{{ v2.id }}', quantity: 1 },
        { id: '{{ v3.id }}', quantity: 1 },
        { id: '{{ v4.id }}', quantity: 1 },
        { id: '{{ v5.id }}', quantity: 1 }
      ].filter(item => item.id && item.id !== ''); // Filter out missing products

      if (items.length === 0) {
        alert("Products could not be found. Please ensure the product handles match the store.");
        return;
      }

      // Update button states
      document.querySelectorAll('.btn-primary').forEach(btn => {
        btn.innerHTML = "Processing...";
        btn.disabled = true;
      });

      // Clear cart first, then add the items, then redirect
      fetch('/cart/clear.js', { method: 'POST' })
        .then(() => {
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ items: items })
          });
        })
        .then(res => res.json())
        .then(() => {
          window.location.href = '/checkout';
        })
        .catch(err => {
          console.error("Error creating bundle checkout:", err);
          alert("There was an error creating your bundle. Please try again.");
          document.querySelectorAll('.btn-primary').forEach(btn => {
            btn.innerHTML = "Buy Now";
            btn.disabled = false;
          });
        });
    }
  </script>

