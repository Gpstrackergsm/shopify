              The Somatic & Trauma Integration Library<br/><span style="font-size:1rem;font-weight:400;margin-top:16px;display:block;">5 Complete Volumes</span>
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  </header>

  <!-- Trust Bar -->
  <div class="trust-bar">
    <div class="container trust-grid">
      <div class="trust-item">
        <div class="trust-icon">🔬</div>
        <div class="trust-title">Evidence-Based</div>
        <div class="trust-desc">Rooted in latest neurobiology</div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">🛠️</div>
        <div class="trust-title">Practical Interventions</div>
        <div class="trust-desc">Ready to use in next session</div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">⚡</div>
        <div class="trust-title">Instant Digital Access</div>
        <div class="trust-desc">Download on any device</div>
      </div>
      <div class="trust-item">
        <div class="trust-icon">🔄</div>
        <div class="trust-title">Integrative Approach</div>
        <div class="trust-desc">Blends IFS, Somatic & Polyvagal</div>
      </div>
    </div>
  </div>

  <!-- Empathy / Problem Section -->
