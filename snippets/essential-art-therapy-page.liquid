    <div class="sl-section-inner">
      <div style="text-align: center; margin-bottom: 48px;">
        <div class="sl-label">Verified Reviews</div>
        <h2 class="sl-title">What Readers Are Saying</h2>
        <div style="display:flex;align-items:center;justify-content:center;gap:12px;margin-top:16px;">
          <span style="color:#f6ad55;font-size:1.5rem;">★★★★★</span>
          <span style="font-size:1.1rem;font-weight:800;color:var(--text-primary);">4.7 out of 5</span>
          <span style="font-size:0.9rem;color:var(--text-secondary);">· Over 3,000 Ratings</span>
        </div>
      </div>
      <div class="sl-reviews-grid">

        <div class="sl-review-card">
          <div class="sl-review-stars">★★★★★</div>
          <div class="sl-review-title">Great art therapy book</div>
          <div class="sl-review-meta">Kristie Withrow &nbsp;·&nbsp; <span class="sl-verified">✓ Verified Purchase</span></div>
          <div class="sl-review-text">Great prompts for art and therapy!!! I love how this is organized.</div>
          <div class="sl-review-helpful">👍 Helpful</div>
        </div>

        <div class="sl-review-card">
          <div class="sl-review-stars">★★★★★</div>
          <div class="sl-review-title">Great Exercises</div>
          <div class="sl-review-meta">kmalgren &nbsp;·&nbsp; <span class="sl-verified">✓ Verified Purchase</span></div>
          <div class="sl-review-text">This was a gift for my wife, who does art therapy. She loves it! Has great exercises.</div>
          <div class="sl-review-helpful">👍 Helpful</div>
        </div>

        <div class="sl-review-card">
          <div class="sl-review-stars">★★★★★</div>
          <div class="sl-review-title">Love this purchase</div>
          <div class="sl-review-meta">Kimberly &nbsp;·&nbsp; <span class="sl-verified">✓ Verified Purchase</span></div>
          <div class="sl-review-text">Whether your counselor are just doing activities on your own, this is a beautiful book with beautiful ideas.</div>
          <div class="sl-review-helpful">👍 1 person found this helpful</div>
        </div>

        <div class="sl-review-card">
          <div class="sl-review-stars">★★★★★</div>
          <div class="sl-review-title">Great book.</div>
          <div class="sl-review-meta">Ms.Chris &nbsp;·&nbsp; <span class="sl-verified">✓ Verified Purchase</span></div>
          <div class="sl-review-text">Yes to this book.</div>
          <div class="sl-review-helpful">👍 Helpful</div>
        </div>
        
        <div class="sl-review-card">
          <div class="sl-review-stars">★★★★★</div>
          <div class="sl-review-title">Exellent!</div>
          <div class="sl-review-meta">R. H. &nbsp;·&nbsp; <span class="sl-verified">✓ Verified Purchase</span></div>
          <div class="sl-review-text">Interesting and easy to understand and follow, this art therapy book is highly recommended for anyone interested in the field of art therapy.</div>
          <div class="sl-review-helpful">👍 Helpful</div>
        </div>

        <div class="sl-review-card">
          <div class="sl-review-stars">★★★★★</div>
          <div class="sl-review-title">Good Exercises</div>
          <div class="sl-review-meta">Own The View Cr8ives &nbsp;·&nbsp; <span class="sl-verified">✓ Verified Purchase</span></div>
          <div class="sl-review-text">This has great exercises for use in art therapy.</div>
          <div class="sl-review-helpful">👍 1 person found this helpful</div>
        </div>

      </div>
    </div>
  </div>

  <!-- FINAL CTA -->
  <div class="sl-cta-section">
    <div class="sl-section-inner">
      <h2 class="sl-title">Find New Peace and Positivity</h2>
      <p class="sl-cta-sub">Join thousands of others in discovering the healing power of art therapy to process emotions and heal from past traumas.</p>
      <form action="/cart/add" method="post" style="margin:0;">
        <input type="hidden" name="id" value="{{ book_variant.id }}">
        <input type="hidden" name="quantity" value="1">
        <input type="hidden" name="return_to" value="/checkout">
        <button type="submit" class="sl-btn-white">
          🛒 Get the Book — {{ book_product.price | money }}
        </button>
      </form>
    </div>
  </div>

  <!-- STICKY BOTTOM ATC -->
  <div class="sl-sticky-cta" id="sticky-cta">
    <div style="font-weight: 700; font-size: 0.95rem;">
      <div style="font-weight: 900; color: var(--text-primary); line-height: 1.2;">Essential Art Therapy Exercises</div>
      <div style="font-size: 0.82rem; color: var(--text-secondary);">Effective Techniques to Manage Anxiety, Depression, and PTSD</div>
    </div>
    <form action="/cart/add" method="post" style="margin:0;">
      <input type="hidden" name="id" value="{{ book_variant.id }}">
      <input type="hidden" name="quantity" value="1">
      <input type="hidden" name="return_to" value="/checkout">
      <button type="submit" class="sl-btn-primary" style="padding: 12px 28px; font-size: 0.95rem;">
        🛒 Buy Now — {{ book_product.price | money }}
      </button>
    </form>
  </div>

  <script>
    const stickyCta = document.getElementById('sticky-cta');
    const heroBtn = document.getElementById('hero-btn');
    window.addEventListener('scroll', () => {
      if (!stickyCta || !heroBtn) return;
      if (heroBtn.getBoundingClientRect().bottom < 0) {
        stickyCta.classList.add('visible');
      } else {
        stickyCta.classList.remove('visible');
      }
    });
    const slObserver = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.style.opacity = '1';
          entry.target.style.transform = 'translateY(0)';
        }
      });
    }, { threshold: 0.1 });
    document.querySelectorAll('.sl-feature-item, .sl-card, .sl-review-card').forEach(el => {
      el.style.opacity = '0';
      el.style.transform = 'translateY(24px)';
      el.style.transition = 'all 0.6s cubic-bezier(0.16, 1, 0.3, 1)';
      slObserver.observe(el);
    });
  </script>

</body>
</html>
