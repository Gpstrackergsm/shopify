{% assign p1 = all_products['dialectical-behavior-therapy-workbook'] %}
{% assign v1 = p1.variants.first %}
{% assign p2 = all_products['essential-art-therapy-exercises-effective-techniques-to-manage-anxiety-depression-and-ptsd'] %}
{% assign v2 = p2.variants.first %}
{% assign p3 = all_products['dont-let-your-emotions-run-your-life-how-dialectical-behavior-therapy-can-put-you-in-control'] %}
{% assign v3 = p3.variants.first %}
{% assign p4 = all_products['somatic-internal-family-systems-therapy-awareness-breath-resonance-movement-and-touch-in-practice-endorsed-by-top-experts-in-therapeutic-healing-modalities'] %}
{% assign v4 = p4.variants.first %}
{% assign p5 = all_products['the-neurodivergent-friendly-workbook-of-dbt-skills'] %}
{% assign v5 = p5.variants.first %}

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>The Complete DBT & Emotional Healing Bundle</title>
  <meta name="description" content="Get five essential books on DBT, emotional regulation, and somatic therapy for one low price of $29. Offer ends soon!" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --brand: #2b6cb0;
      --brand-dark: #1a365d;
      --brand-light: #ebf8ff;
      --accent: #e53e3e;
      --accent-hover: #c53030;
      --text-primary: #1a202c;
      --text-secondary: #4a5568;
      --bg: #ffffff;
      --surface: #f7fafc;
      --border: #e2e8f0;
      --shadow: 0 4px 6px rgba(0, 0, 0, 0.05);
      --glass-bg: rgba(255, 255, 255, 0.9);
    }
    body { font-family: 'Inter', sans-serif; background: var(--bg); color: var(--text-primary); line-height: 1.6; }

    /* Navigation */
    .bundle-nav { position: sticky; top: 0; z-index: 1000; background: var(--glass-bg); backdrop-filter: blur(10px); border-bottom: 1px solid var(--border); padding: 0 24px; }
    .bundle-nav-inner { max-width: 1100px; margin: 0 auto; display: flex; align-items: center; justify-content: space-between; height: 64px; }
    .bundle-logo { font-weight: 900; font-size: 1.25rem; color: var(--brand); text-decoration: none; }
    
    /* Buttons */
    .btn { display: inline-flex; align-items: center; justify-content: center; gap: 8px; font-weight: 800; border-radius: 12px; cursor: pointer; transition: all 0.2s ease; border: none; font-size: 1.1rem; padding: 16px 32px; font-family: inherit; }
    .btn-primary { background: linear-gradient(135deg, var(--accent), var(--accent-hover)); color: #fff; box-shadow: 0 4px 14px rgba(229, 62, 62, 0.3); }
    .btn-primary:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(229, 62, 62, 0.4); }
    .btn-sm { font-size: 0.95rem; padding: 10px 20px; border-radius: 8px; }

    /* Hero */
    .bundle-hero { background: linear-gradient(135deg, var(--surface) 0%, var(--brand-light) 100%); padding: 80px 24px; text-align: center; }
    .hero-badge { display: inline-block; background: var(--accent); color: #fff; font-size: 0.85rem; font-weight: 800; padding: 6px 16px; border-radius: 999px; margin-bottom: 24px; text-transform: uppercase; letter-spacing: 1px; }
    .bundle-hero h1 { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; color: var(--brand-dark); line-height: 1.1; margin-bottom: 24px; letter-spacing: -1px; }
    .bundle-hero p { font-size: 1.25rem; color: var(--text-secondary); max-width: 600px; margin: 0 auto 30px; }
    .price-block { margin-bottom: 24px; }
    .price-current { font-size: 3rem; font-weight: 900; color: var(--text-primary); }
    .price-original { font-size: 1.25rem; text-decoration: line-through; color: #a0aec0; margin-left: 12px; font-weight: 600; }
    .urgency-text { color: var(--accent); font-weight: 800; font-size: 1.2rem; margin-bottom: 32px; display: inline-block; padding: 10px 24px; background: rgba(229,62,62,0.1); border-radius: 12px; border: 1px solid rgba(229,62,62,0.2); }

    /* Books Grid */
    .books-section { padding: 80px 24px; background: #fff; }
    .section-title { text-align: center; font-size: 2.5rem; font-weight: 900; margin-bottom: 48px; color: var(--brand-dark); }
    .books-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 32px; max-width: 1200px; margin: 0 auto; justify-content: center; }
    .book-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 32px; text-align: center; transition: transform 0.3s ease; display: flex; flex-direction: column; justify-content: space-between; }
    .book-card:hover { transform: translateY(-8px); box-shadow: 0 12px 24px rgba(0,0,0,0.06); }
    .book-img { width: 100%; max-width: 180px; height: 250px; object-fit: contain; margin: 0 auto 24px; border-radius: 8px; box-shadow: 0 8px 16px rgba(0,0,0,0.1); }
    .book-title { font-size: 1.15rem; font-weight: 800; line-height: 1.3; margin-bottom: 12px; color: var(--text-primary); }
    
    /* Trust Bar */
    .trust-bar { display: flex; flex-wrap: wrap; justify-content: center; gap: 40px; padding: 40px 24px; background: var(--brand-dark); color: #fff; }
    .trust-item { display: flex; align-items: center; gap: 12px; font-weight: 600; font-size: 1.1rem; }

    /* Sticky Bottom CTA */
    .sticky-cta { position: fixed; bottom: 0; left: 0; right: 0; background: var(--glass-bg); backdrop-filter: blur(10px); border-top: 1px solid var(--border); padding: 16px 24px; z-index: 999; display: flex; justify-content: center; align-items: center; gap: 24px; box-shadow: 0 -4px 20px rgba(0,0,0,0.05); transform: translateY(100%); transition: transform 0.3s ease; }
    .sticky-cta.show { transform: translateY(0); }
    .sticky-cta-text { font-weight: 800; font-size: 1.1rem; }

    @media (max-width: 768px) {
      .bundle-hero h1 { font-size: 2.2rem; }
      .sticky-cta { flex-direction: column; text-align: center; gap: 12px; }
      .books-grid { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
      .urgency-text { font-size: 1.05rem; }
    }
  </style>
</head>
<body>

  <nav class="bundle-nav">
    <div class="bundle-nav-inner">
      <a href="/" class="bundle-logo">PsychoReads</a>
      <button class="btn btn-primary btn-sm" onclick="checkoutBundle()">Buy Bundle Now</button>
    </div>
  </nav>

  <header class="bundle-hero">
    <div class="hero-badge">Ending Soon</div>
    <h1>The Complete DBT & Emotional Healing Bundle</h1>
    <p>Master Emotional Regulation, DBT Skills, and Somatic Therapy with this ultimate collection.</p>
    
    <div class="price-block">
      <span class="price-current">$29.00</span>
      <span class="price-original">$145.00 Value</span>
    </div>

    <div>
      <div class="urgency-text">
        ⚠️ Hurry, this bundle price of $29 ends soon!
      </div>
    </div>

    <button id="hero-btn" class="btn btn-primary" onclick="checkoutBundle()">
      🛒 Get All 5 Books for $29
    </button>
    <div style="margin-top: 16px; font-size: 0.9rem; color: var(--text-secondary); font-weight: 500;">
      Instant PDF Download • Secure Checkout
    </div>
  </header>

  <div class="trust-bar">
    <div class="trust-item"><span>📘</span> 5 Complete Books</div>
    <div class="trust-item"><span>⚡</span> Instant Digital Access</div>
    <div class="trust-item"><span>🧠</span> Regulate Your Emotions</div>
  </div>

  <section class="books-section">
    <h2 class="section-title">What's Inside The Bundle</h2>
    <div class="books-grid">
      
      <!-- Book 1 -->
      <div class="book-card">
        {% if p1.images.first %}
          <img src="{{ p1.images.first | img_url: '600x' }}" alt="{{ p1.title }}" class="book-img" loading="lazy" />
        {% else %}
          <div class="book-img" style="background: #e2e8f0; display:flex; align-items:center; justify-content:center; padding: 20px;">Book 1</div>
        {% endif %}
        <h3 class="book-title">{{ p1.title | default: "Dialectical Behavior Therapy Workbook" }}</h3>
      </div>

      <!-- Book 2 -->
      <div class="book-card">
        {% if p2.images.first %}
          <img src="{{ p2.images.first | img_url: '600x' }}" alt="{{ p2.title }}" class="book-img" loading="lazy" />
        {% else %}
          <div class="book-img" style="background: #e2e8f0; display:flex; align-items:center; justify-content:center; padding: 20px;">Book 2</div>
        {% endif %}
        <h3 class="book-title">{{ p2.title | default: "Essential Art Therapy Exercises" }}</h3>
      </div>

      <!-- Book 3 -->
      <div class="book-card">
        {% if p3.images.first %}
          <img src="{{ p3.images.first | img_url: '600x' }}" alt="{{ p3.title }}" class="book-img" loading="lazy" />
        {% else %}
          <div class="book-img" style="background: #e2e8f0; display:flex; align-items:center; justify-content:center; padding: 20px;">Book 3</div>
        {% endif %}
        <h3 class="book-title">{{ p3.title | default: "Don't Let Your Emotions Run Your Life" }}</h3>
      </div>

      <!-- Book 4 -->
      <div class="book-card">
        {% if p4.images.first %}
          <img src="{{ p4.images.first | img_url: '600x' }}" alt="{{ p4.title }}" class="book-img" loading="lazy" />
        {% else %}
          <div class="book-img" style="background: #e2e8f0; display:flex; align-items:center; justify-content:center; padding: 20px;">Book 4</div>
        {% endif %}
        <h3 class="book-title">{{ p4.title | default: "Somatic Internal Family Systems Therapy" }}</h3>
      </div>

      <!-- Book 5 -->
      <div class="book-card">
        {% if p5.images.first %}
          <img src="{{ p5.images.first | img_url: '600x' }}" alt="{{ p5.title }}" class="book-img" loading="lazy" />
        {% else %}
          <div class="book-img" style="background: #e2e8f0; display:flex; align-items:center; justify-content:center; padding: 20px;">Book 5</div>
        {% endif %}
        <h3 class="book-title">{{ p5.title | default: "The Neurodivergent Friendly Workbook of DBT Skills" }}</h3>
      </div>

    </div>
  </section>

  <div class="bundle-hero" style="background: var(--brand-dark); color: #fff;">
    <h2 style="font-size: 2.5rem; margin-bottom: 24px; color: #fff;">Start Your Healing Journey Today</h2>
    <p style="color: rgba(255,255,255,0.8); margin-bottom: 16px;">Get instant access to all five books and begin applying these techniques immediately.</p>
    <p style="color: #fc8181; font-weight: 800; font-size: 1.1rem; margin-bottom: 32px;">⚠️ Limited Time: This $29 offer ends soon!</p>
    <button class="btn btn-primary" onclick="checkoutBundle()" style="background: #fff; color: var(--accent); box-shadow: none;">
      🛒 Get The Bundle — $29
    </button>
  </div>

  <div class="sticky-cta" id="sticky-cta">
    <div class="sticky-cta-text">
      <span style="display:block;">DBT & Emotional Healing Bundle</span>
      <span style="font-size: 0.85rem; color: var(--accent); font-weight: 700;">Hurry, $29 offer ends soon!</span>
    </div>
    <button class="btn btn-primary btn-sm" onclick="checkoutBundle()">Buy Now</button>
  </div>

  <script>
    // Reveal sticky CTA on scroll
    const heroBtn = document.getElementById('hero-btn');
    const stickyCta = document.getElementById('sticky-cta');
    
    window.addEventListener('scroll', () => {
      if (heroBtn.getBoundingClientRect().bottom < 0) {
        stickyCta.classList.add('show');
      } else {
        stickyCta.classList.remove('show');
      }
    });

    // Handle Add to Cart & Checkout
    function checkoutBundle() {
      const variants = [
        '{{ v1.id }}', '{{ v2.id }}', '{{ v3.id }}', 
        '{{ v4.id }}', '{{ v5.id }}'
      ];

      if (variants.some(v => !v)) {
        alert("Bundle configuration error. Missing variants.");
        return;
      }

      // Update button states
      document.querySelectorAll('.btn-primary').forEach(btn => {
        btn.innerHTML = "Processing...";
        btn.disabled = true;
      });

      const items = variants.map(id => ({ id: id, quantity: 1 }));

      // Clear cart first, then add the items, then redirect
      fetch('/cart/clear.js', { method: 'POST' })
        .then(() => {
          return fetch('/cart/add.js', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
            body: JSON.stringify({ items: items })
          });
        })
        .then(res => res.json())
        .then(() => {
          window.location.href = '/checkout';
        })
        .catch(err => {
          console.error("Error creating bundle checkout:", err);
          alert("There was an error creating your bundle. Please try again.");
          document.querySelectorAll('.btn-primary').forEach(btn => {
            btn.innerHTML = "Buy Bundle Now";
            btn.disabled = false;
          });
        });
    }
  </script>

</body>
</html>
