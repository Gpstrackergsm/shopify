<style>
  .sdbp-wrap *, .sdbp-wrap *::before, .sdbp-wrap *::after { box-sizing: border-box; margin: 0; padding: 0; }

  .sdbp-wrap {
    --c-bg: #070913;
    --c-bg2: #0d1020;
    --c-bg3: #13172e;
    --c-glass: rgba(255,255,255,0.04);
    --c-border: rgba(255,255,255,0.07);
    --c-purple: #a78bfa;
    --c-purple2: #7c3aed;
    --c-purple-glow: rgba(167,139,250,0.18);
    --c-teal: #2dd4bf;
    --c-teal2: #0d9488;
    --c-teal-glow: rgba(45,212,191,0.18);
    --c-rose: #fb7185;
    --c-gold: #fbbf24;
    --c-text: #f1f5f9;
    --c-muted: #64748b;
    --c-dim: #94a3b8;
    --c-radius: 20px;
    --c-ease: all 0.35s cubic-bezier(0.4,0,0.2,1);
    font-family: 'Outfit', sans-serif;
    background: var(--c-bg);
    color: var(--c-text);
    overflow-x: hidden;
  }

  /* ── HERO ── */
  .sdbp-hero {
    min-height: 90vh;
    display: flex; align-items: center; justify-content: center;
    text-align: center;
    padding: 60px 24px 80px;
    position: relative; overflow: hidden;
  }
  .sdbp-orb { position:absolute; border-radius:50%; filter:blur(120px); pointer-events:none; }
  .sdbp-orb-1 { width:700px;height:700px;background:radial-gradient(circle,rgba(45,212,191,0.12),transparent 70%);top:-180px;left:50%;transform:translateX(-50%); }
  .sdbp-orb-2 { width:420px;height:420px;background:radial-gradient(circle,rgba(167,139,250,0.12),transparent 70%);bottom:0;right:-80px; }
  .sdbp-orb-3 { width:350px;height:350px;background:radial-gradient(circle,rgba(251,113,133,0.06),transparent 70%);bottom:0;left:-60px; }

  .sdbp-hero-inner { position:relative;z-index:1;max-width:850px; }

  .sdbp-badge {
    display:inline-flex;align-items:center;gap:8px;
    background:rgba(45,212,191,0.08);
    border:1px solid rgba(45,212,191,0.25);
    border-radius:999px;padding:8px 22px;
    font-size:0.78rem;font-weight:800;letter-spacing:2px;text-transform:uppercase;
    color:var(--c-teal);margin-bottom:28px;backdrop-filter:blur(12px);
  }
  .sdbp-badge-dot {
    width:7px;height:7px;background:var(--c-teal);border-radius:50%;
    animation:sdbp-pulse 2s ease-in-out infinite;
  }
  @keyframes sdbp-pulse { 0%,100%{opacity:1;transform:scale(1);}50%{opacity:0.4;transform:scale(0.7);} }

  .sdbp-hero h1 {
    font-size:clamp(2.5rem,6vw,4.6rem);font-weight:900;line-height:1.08;
    letter-spacing:-2px;margin-bottom:24px;
  }
  .sdbp-teal-text {
    background:linear-gradient(135deg,var(--c-teal),#0d9488);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  }
  .sdbp-purple-text {
    background:linear-gradient(135deg,var(--c-purple),#c084fc);
    -webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text;
  }

  .sdbp-sub {
    font-size:1.15rem;color:var(--c-dim);max-width:620px;
    margin:0 auto 44px;line-height:1.75;font-weight:400;
  }

  /* Price */
  .sdbp-price-row { display:flex;align-items:center;justify-content:center;gap:20px;margin-bottom:36px;flex-wrap:wrap; }
  .sdbp-price-main { font-size:5.5rem;font-weight:900;line-height:1;letter-spacing:-4px;color:var(--c-text); }
  .sdbp-price-main sup { font-size:2.2rem;letter-spacing:0;vertical-align:super; }
  .sdbp-price-meta { display:flex;flex-direction:column;align-items:flex-start;gap:6px; }
  .sdbp-price-was { font-size:1.1rem;color:var(--c-muted);text-decoration:line-through;font-weight:600; }
  .sdbp-save-pill {
    font-size:0.82rem;font-weight:800;color:var(--c-teal);
    background:rgba(45,212,191,0.12);padding:4px 12px;border-radius:999px;
    letter-spacing:0.5px;border:1px solid rgba(45,212,191,0.25);
  }

  /* Button */
  .sdbp-btn {
    display:inline-flex;align-items:center;gap:10px;
    font-family:'Outfit',sans-serif;font-weight:800;
    border:none;border-radius:16px;cursor:pointer;
    transition:var(--c-ease);text-decoration:none;
    position:relative;overflow:hidden;letter-spacing:-0.3px;
  }
  .sdbp-btn::after { content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,0.18),transparent);opacity:0;transition:opacity 0.2s; }
  .sdbp-btn:hover::after { opacity:1; }
  .sdbp-btn-primary {
    background:linear-gradient(135deg,var(--c-teal),var(--c-teal2));
    color:#fff;padding:18px 52px;font-size:1.15rem;
    box-shadow:0 0 40px var(--c-teal-glow),0 6px 20px rgba(0,0,0,0.4);
  }
  .sdbp-btn-primary:hover { transform:translateY(-3px);box-shadow:0 0 60px var(--c-teal-glow),0 10px 30px rgba(0,0,0,0.5); }
  .sdbp-btn-sm { font-size:0.9rem;padding:11px 24px;border-radius:12px; }

  .sdbp-trust { display:flex;align-items:center;justify-content:center;gap:24px;margin-top:22px;flex-wrap:wrap; }
  .sdbp-trust-item { display:flex;align-items:center;gap:6px;font-size:0.82rem;color:var(--c-muted);font-weight:500; }
  .sdbp-trust-item svg { color:var(--c-teal); }

  /* ── EXPLAINER ── */
  .sdbp-explainer {
    padding:80px 24px;
    background:linear-gradient(135deg,rgba(45,212,191,0.05),rgba(167,139,250,0.03));
    border-top:1px solid var(--c-border);border-bottom:1px solid var(--c-border);
    text-align:center;
  }
  .sdbp-explainer-inner { max-width:800px;margin:0 auto; }
  .sdbp-explainer h2 { font-size:clamp(1.6rem,3.5vw,2.4rem);font-weight:900;letter-spacing:-1px;margin-bottom:18px; }
  .sdbp-explainer p { font-size:1.05rem;color:var(--c-dim);line-height:1.8; }
  .sdbp-concept-row { display:flex;align-items:stretch;justify-content:center;gap:24px;margin-top:48px;flex-wrap:wrap; }
  .sdbp-concept {
    background:var(--c-glass);border:1px solid var(--c-border);
    border-radius:16px;padding:24px;text-align:left;flex:1;min-width:240px;
    backdrop-filter:blur(10px);
  }
  .sdbp-concept-icon { font-size:2rem;margin-bottom:14px;display:block; }
  .sdbp-concept-title { font-size:1.1rem;font-weight:800;color:var(--c-text);margin-bottom:8px; }
  .sdbp-concept-text { font-size:0.88rem;color:var(--c-dim);line-height:1.6; }

  /* ── BOOKS GRID ── */
  .sdbp-books { padding:100px 24px; }
  .sdbp-label { display:block;text-align:center;font-size:0.73rem;font-weight:800;letter-spacing:3px;text-transform:uppercase;color:var(--c-teal);margin-bottom:14px; }
  .sdbp-title { text-align:center;font-size:clamp(1.8rem,4vw,2.8rem);font-weight:900;letter-spacing:-1.5px;margin-bottom:60px;color:var(--c-text); }

  .sdbp-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:32px;max-width:1100px;margin:0 auto; }

  .sdbp-card {
    background:var(--c-glass);border:1px solid var(--c-border);border-radius:var(--c-radius);
    padding:36px 24px;display:flex;flex-direction:column;align-items:center;
    text-align:center;transition:var(--c-ease);backdrop-filter:blur(10px);
    position:relative;overflow:hidden;justify-content:space-between;
  }
  .sdbp-card::before { content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(45,212,191,0.06),transparent,rgba(167,139,250,0.04));opacity:0;transition:opacity 0.3s; }
  .sdbp-card:hover { transform:translateY(-10px);border-color:rgba(45,212,191,0.35);box-shadow:0 24px 60px rgba(0,0,0,0.5),0 0 40px var(--c-teal-glow); }
  .sdbp-card:hover::before { opacity:1; }

  .sdbp-card-num { position:absolute;top:14px;right:14px;width:30px;height:30px;background:linear-gradient(135deg,var(--c-teal),var(--c-teal2));border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:900;color:#fff; }

  .sdbp-cover-wrap { width:130px;height:195px;margin-bottom:24px;position:relative;flex-shrink:0; }
  .sdbp-cover-wrap::after { content:'';position:absolute;bottom:-10px;left:50%;transform:translateX(-50%);width:75%;height:18px;background:var(--c-teal-glow);filter:blur(14px);border-radius:50%;opacity:0;transition:opacity 0.3s; }
  .sdbp-card:hover .sdbp-cover-wrap::after { opacity:1; }

  .sdbp-cover { width:100%;height:100%;object-fit:contain;border-radius:6px;box-shadow:0 14px 40px rgba(0,0,0,0.6),4px 4px 0 rgba(0,0,0,0.25);transition:transform 0.35s ease; }
  .sdbp-card:hover .sdbp-cover { transform:rotate(-2.5deg) scale(1.05); }
  .sdbp-card-title { font-size:0.92rem;font-weight:700;line-height:1.4;color:var(--c-text); }

  /* ── FEATURES ── */
  .sdbp-features { padding:80px 24px;background:var(--c-bg2);border-top:1px solid var(--c-border);border-bottom:1px solid var(--c-border); }
  .sdbp-feat-grid { display:grid;grid-template-columns:repeat(3,1fr);gap:32px;max-width:1000px;margin:0 auto; }
  .sdbp-feat { text-align:center;padding:36px 20px; }
  .sdbp-feat-icon { font-size:2.6rem;margin-bottom:16px;display:block; }
  .sdbp-feat-title { font-size:1.05rem;font-weight:800;margin-bottom:10px;color:var(--c-text); }
  .sdbp-feat-desc { font-size:0.88rem;color:var(--c-muted);line-height:1.75; }

  /* ── FINAL CTA ── */
  .sdbp-final { padding:120px 24px;text-align:center;position:relative;overflow:hidden; }
  .sdbp-final-orb { position:absolute;width:700px;height:700px;border-radius:50%;background:radial-gradient(circle,rgba(45,212,191,0.1),transparent 70%);top:50%;left:50%;transform:translate(-50%,-50%);filter:blur(80px);pointer-events:none; }
  .sdbp-final-inner { position:relative;z-index:1;max-width:640px;margin:0 auto; }
  .sdbp-final h2 { font-size:clamp(2rem,4vw,3.4rem);font-weight:900;letter-spacing:-1.5px;margin-bottom:18px;line-height:1.1; }
  .sdbp-final p { font-size:1.1rem;color:var(--c-dim);margin-bottom:44px;line-height:1.75; }

  /* ── STICKY ── */
  .sdbp-sticky { position:fixed;bottom:0;left:0;right:0;z-index:999;padding:16px 32px;background:rgba(7,9,19,0.9);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border-top:1px solid var(--c-border);display:flex;align-items:center;justify-content:center;gap:32px;transform:translateY(100%);transition:transform 0.4s cubic-bezier(0.4,0,0.2,1);box-shadow:0 -20px 60px rgba(0,0,0,0.6); }
  .sdbp-sticky.show { transform:translateY(0); }
  .sdbp-sticky-text { font-size:1rem;font-weight:700;color:var(--c-text); }
  .sdbp-sticky-text span { color:var(--c-teal); }

  /* ── FADE ── */
  .sdbp-fade { opacity:0;transform:translateY(32px);transition:opacity 0.75s ease,transform 0.75s ease; }
  .sdbp-fade.in { opacity:1;transform:translateY(0); }
  .sdbp-fade:nth-child(2){transition-delay:0.1s}.sdbp-fade:nth-child(3){transition-delay:0.2s}
  .sdbp-fade:nth-child(4){transition-delay:0.3s}.sdbp-fade:nth-child(5){transition-delay:0.4s}
  .sdbp-fade:nth-child(6){transition-delay:0.5s}

  @media(max-width:900px){ .sdbp-grid{grid-template-columns:repeat(2,1fr);} .sdbp-feat-grid{grid-template-columns:1fr;} .sdbp-concept-row{gap:16px;} }
  @media(max-width:600px){ .sdbp-grid{grid-template-columns:repeat(2,1fr);gap:14px;} .sdbp-card{padding:20px 14px;} .sdbp-hero h1{letter-spacing:-1.5px;} .sdbp-sticky{flex-direction:column;gap:10px;padding:14px 20px;} .sdbp-price-main{font-size:4rem;} }
</style>

