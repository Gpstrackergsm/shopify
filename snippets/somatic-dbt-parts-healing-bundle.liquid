<!-- STICKY BAR -->
<div class="sdbp-sticky" id="sdbp-sticky">
  <span class="sdbp-sticky-text">Somatic, DBT & Parts Healing Bundle — <span>$29.00</span></span>
  <button class="sdbp-btn sdbp-btn-primary sdbp-btn-sm" onclick="sdbpCheckout()">Buy Now</button>
</div>

<script>
  const sdbpHeroCta = document.getElementById('sdbp-hero-cta');
  const sdbpSticky  = document.getElementById('sdbp-sticky');
  window.addEventListener('scroll', () => {
    if (sdbpSticky && sdbpHeroCta) {
      sdbpSticky.classList.toggle('show', sdbpHeroCta.getBoundingClientRect().bottom < 0);
    }
  }, { passive: true });

  const sdbpFades = document.querySelectorAll('.sdbp-fade');
  const sdbpObs = new IntersectionObserver((entries) => {
    entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('in'); sdbpObs.unobserve(e.target); } });
  }, { threshold: 0.1 });
  sdbpFades.forEach(el => sdbpObs.observe(el));

  function sdbpCheckout() {
    const variants = [
      '{{ v1.id }}','{{ v2.id }}','{{ v3.id }}',
      '{{ v4.id }}','{{ v5.id }}','{{ v6.id }}'
    ];
    if (variants.some(v => !v || v === '')) { alert('Bundle error. Please try again.'); return; }
    document.querySelectorAll('.sdbp-btn-primary').forEach(b => { b.textContent = 'Processing…'; b.disabled = true; });
    fetch('/cart/clear.js', { method: 'POST' })
      .then(() => fetch('/cart/add.js', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
        body: JSON.stringify({ items: variants.map(id => ({ id: parseInt(id), quantity: 1 })) })
      }))
      .then(r => r.json())
      .then(() => { window.location.href = '/checkout'; })
      .catch(err => {
        console.error(err);
        document.querySelectorAll('.sdbp-btn-primary').forEach(b => { b.textContent = 'Get Bundle — $29'; b.disabled = false; });
        alert('Something went wrong. Please try again.');
      });
  }
</script>
